{
  "name": "desktop-shadertoy",
  "version": "0.4.4",
  "description": "Desktop Shadertoy",
  "homepage": "https://github.com/GabeRundlett/desktop-shadertoy",
  "dependencies": [
    "stb",
    "nlohmann-json",

    "vulkan-memory-allocator",
    "vulkan-headers",
    "vulkan",
    "glslang",

    "glfw3",
    "fmt",
    {
      "name": "imgui",
      "features": [
        "glfw-binding",
        "vulkan-binding"
      ]
    },
    "openssl",
    "boost-asio",
    "boost-beast",
    "nativefiledialog"
  ],
  "builtin-baseline": "b346ee32f13f3bf2ef19ac02f982f6938f7a84ea",
  "vcpkg-configuration": {
    "overlay-ports": [
      "cmake/overlay-ports/glslang"
    ]
  }
}
